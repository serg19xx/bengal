---
import type { Locale } from "../i18n/config";
import { getMessages } from "../i18n/messages";
import { pathFor, swapLocaleInPath } from "../i18n/paths";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const m = getMessages(lang);

const nav = [
  { href: pathFor(lang), label: m.nav.home },
  { href: pathFor(lang, "about"), label: m.nav.about },
  { href: pathFor(lang, "cats"), label: m.nav.cats },
  { href: pathFor(lang, "kittens"), label: m.nav.available },
  { href: pathFor(lang, "gallery"), label: m.nav.gallery },
  { href: pathFor(lang, "adoption"), label: m.nav.adoption },
  { href: pathFor(lang, "varieties"), label: m.nav.varieties },
  { href: pathFor(lang, "contact"), label: m.nav.contact },
];

const pathname = Astro.url.pathname;
---

<header
  class="fixed inset-x-0 top-0 z-[10000] w-full border-b border-beige-300/60 bg-cream-50/95 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-4 sm:px-6">
    <a
      href={pathFor(lang)}
      class="group flex min-w-0 items-center gap-2 rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-soft-700"
    >
      <span
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-soft-800 text-cream-50 font-serif text-lg font-semibold shadow-sm"
        aria-hidden="true"
      >
        W
      </span>
      <span class="flex min-w-0 flex-col leading-tight">
        <span class="font-serif text-lg font-semibold text-soft-900 group-hover:text-soft-800 truncate">{m.brand.line1}</span>
        <span class="text-xs font-medium uppercase tracking-wider text-warm-500">{m.brand.line2}</span>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-2">
      <nav class="flex flex-wrap items-center justify-end gap-0.5" aria-label={m.header.mainNav}>
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="rounded-xl px-2.5 py-2 text-sm font-medium text-warm-600 hover:text-soft-900 hover:bg-cream-200/80 transition"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="ml-1 flex items-center gap-1 rounded-2xl border border-beige-300 bg-white p-0.5 text-xs font-semibold shadow-sm">
        <a
          href={swapLocaleInPath(pathname, "en")}
          class:list={[
            "rounded-xl px-2.5 py-1.5 transition",
            lang === "en" ? "bg-cream-200 text-soft-900" : "text-warm-600 hover:text-soft-900",
          ]}
          hreflang="en"
          lang="en"
        >
          EN
        </a>
        <a
          href={swapLocaleInPath(pathname, "fr")}
          class:list={[
            "rounded-xl px-2.5 py-1.5 transition",
            lang === "fr" ? "bg-cream-200 text-soft-900" : "text-warm-600 hover:text-soft-900",
          ]}
          hreflang="fr"
          lang="fr"
        >
          FR
        </a>
      </div>
    </div>

    <details class="relative md:hidden group">
      <summary
        class="list-none cursor-pointer rounded-2xl border border-beige-300 bg-white px-3 py-2 text-sm font-semibold text-soft-800 shadow-sm hover:bg-cream-100 transition [&::-webkit-details-marker]:hidden"
        aria-label={m.header.menu}
      >
        <span class="inline-flex items-center gap-2">
          {m.header.menu}
          <svg class="h-4 w-4 text-warm-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M3 5h14v2H3V5zm0 4h14v2H3V9zm0 4h14v2H3v-2z"
              clip-rule="evenodd"
            />
          </svg>
        </span>
      </summary>
      <div
        class="absolute right-0 z-[10001] mt-2 w-56 max-h-[70vh] overflow-y-auto overflow-x-hidden rounded-2xl border border-beige-300 bg-white py-2 shadow-lg shadow-soft-900/10"
      >
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="block px-4 py-2.5 text-sm font-medium text-warm-600 hover:bg-cream-100 hover:text-soft-900"
            >
              {item.label}
            </a>
          ))
        }
        <div class="mt-2 border-t border-cream-200 px-4 py-3 flex gap-2">
          <a
            href={swapLocaleInPath(pathname, "en")}
            class="flex-1 rounded-xl border border-beige-300 py-2 text-center text-xs font-semibold text-soft-800"
            hreflang="en"
          >
            EN
          </a>
          <a
            href={swapLocaleInPath(pathname, "fr")}
            class="flex-1 rounded-xl border border-beige-300 py-2 text-center text-xs font-semibold text-soft-800"
            hreflang="fr"
          >
            FR
          </a>
        </div>
      </div>
    </details>
  </div>
</header>
