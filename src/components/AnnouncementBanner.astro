---
interface Props {
  text: string;
  href: string;
  ctaLabel: string;
}

const { text, href, ctaLabel } = Astro.props;
---

<div
  class="mb-2 flex flex-col gap-3 rounded-2xl border border-beige-300/70 bg-cream-100/90 px-5 py-4 sm:flex-row sm:items-center sm:justify-between"
  role="status"
>
  <p class="text-sm font-medium leading-relaxed text-soft-800 max-w-2xl">{text}</p>
  <a href={href} class="btn-brush shrink-0 self-start sm:self-center">
    {ctaLabel}
  </a>
</div>
