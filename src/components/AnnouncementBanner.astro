---
interface Props {
  text: string;
  href: string;
  ctaLabel: string;
}

const { text, href, ctaLabel } = Astro.props;
---

<div
  class="mb-8 flex flex-col gap-3 rounded-2xl border border-beige-300/80 bg-cream-200/60 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6"
  role="status"
>
  <p class="text-sm font-medium text-soft-900">{text}</p>
  <a
    href={href}
    class="inline-flex shrink-0 items-center justify-center rounded-xl bg-soft-800 px-4 py-2.5 text-xs font-semibold text-cream-50 hover:bg-soft-700 transition"
  >
    {ctaLabel}
  </a>
</div>
