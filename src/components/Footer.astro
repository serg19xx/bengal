---
import type { Locale } from "../i18n/config";
import { getMessages } from "../i18n/messages";
import { pathFor } from "../i18n/paths";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const m = getMessages(lang);
const year = new Date().getFullYear();

const moreLinks = [
  { href: pathFor(lang, "about"), label: m.nav.about },
  { href: pathFor(lang, "adoption"), label: m.nav.adoption },
  { href: pathFor(lang, "varieties"), label: m.nav.varieties },
];
---

<footer class="mt-16 border-t border-beige-300/40 bg-cream-100/70">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="font-serif text-xl font-semibold text-soft-900">{m.brand.line1}</p>
        <p class="font-script text-xl text-amber-500 mt-1">{m.brand.line2}</p>
        <p class="mt-2 max-w-sm text-sm leading-relaxed text-warm-600">{m.footer.blurb}</p>
      </div>
      <div class="flex flex-col gap-8 sm:flex-row sm:gap-12">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-warm-500">{m.footer.moreLabel}</p>
          <ul class="mt-3 flex flex-col gap-2 text-sm">
            {
              moreLinks.map((item) => (
                <li>
                  <a href={item.href} class="text-soft-800 underline-offset-4 hover:underline">
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-warm-500">{m.footer.socialLabel}</p>
          <ul class="mt-3 flex flex-wrap gap-3 text-sm">
            <li>
              <a href="#" class="text-soft-800 underline-offset-4 hover:underline">{m.footer.instagram}</a>
            </li>
            <li>
              <a href="#" class="text-soft-800 underline-offset-4 hover:underline">{m.footer.facebook}</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
    <p class="mt-10 text-xs text-warm-500">© {year} {m.meta.siteName}. {m.footer.legal}</p>
  </div>
</footer>
