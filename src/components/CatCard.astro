---
import type { Locale } from "../i18n/config";
import { getMessages } from "../i18n/messages";
import { pathFor } from "../i18n/paths";
import type { Cat, CatStatus } from "../data/cats";
import { displayAgeLine, formatCatBirthDate, pickLocalized } from "../data/cats";

interface Props {
  cat: Cat;
  lang: Locale;
}

const { cat, lang } = Astro.props;
const m = getMessages(lang);

const statusStyles: Record<CatStatus, string> = {
  Available: "bg-emerald-100 text-emerald-900 border-emerald-200/80",
  Reserved: "bg-amber-100 text-amber-950 border-amber-200/80",
  Sold: "bg-warm-400/30 text-warm-600 border-warm-400/50",
  "Not for sale": "bg-cream-200 text-soft-800 border-beige-300",
};

const href = pathFor(lang, "cats", cat.slug);
const breed = pickLocalized(cat.breed, lang);
const personalityShort = pickLocalized(cat.personalityShort, lang);
const statusLabel = m.status[cat.status];
const genderLabel = m.gender[cat.gender];
const showBirth =
  Boolean(cat.birthDate) && /^\d{4}-\d{2}-\d{2}$/.test(cat.birthDate!);
const birthOrAgeLabel = showBirth ? m.catCard.birthDate : m.catCard.age;
const birthOrAgeValue = showBirth ? formatCatBirthDate(cat.birthDate!, lang) : displayAgeLine(cat, lang);
---

<article
  class="group flex flex-col overflow-hidden rounded-3xl border border-beige-300/70 bg-white shadow-sm shadow-soft-900/5 transition hover:shadow-md hover:border-beige-300"
>
  <a href={href} class="block relative aspect-[4/3] overflow-hidden bg-cream-100">
    <img
      src={cat.coverImage}
      alt={`${cat.name}, ${breed}`}
      class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
      loading="lazy"
      width="800"
      height="600"
    />
    <span
      class:list={[
        "absolute right-3 top-3 rounded-full border px-3 py-1 text-xs font-semibold backdrop-blur-sm",
        statusStyles[cat.status],
      ]}
    >
      {statusLabel}
    </span>
  </a>
  <div class="flex flex-1 flex-col p-5 sm:p-6">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h3 class="font-serif text-xl font-semibold text-soft-900">
          <a href={href} class="hover:text-soft-700 transition">{cat.name}</a>
        </h3>
        <p class="mt-1 text-sm text-warm-500">{breed}</p>
      </div>
    </div>
    <p class="mt-3 text-sm text-warm-600 leading-relaxed line-clamp-3">{personalityShort}</p>
    <dl class="mt-4 grid grid-cols-2 gap-2 text-xs text-warm-500">
      <div>
        <dt class="font-medium text-warm-600">{birthOrAgeLabel}</dt>
        <dd>{birthOrAgeValue}</dd>
      </div>
      <div>
        <dt class="font-medium text-warm-600">{m.catCard.gender}</dt>
        <dd>{genderLabel}</dd>
      </div>
    </dl>
    <div class="mt-5 pt-4 border-t border-cream-200">
      <a href={href} class="text-sm font-semibold text-soft-800 hover:text-soft-700 inline-flex items-center gap-1">
        {m.catCard.viewProfile}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</article>
