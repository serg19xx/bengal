---
import InkBanner from "./InkBanner.astro";

interface LinkItem {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

interface Props {
  title?: string;
  description?: string;
  links: LinkItem[];
}

const { title = "Ready to meet our cats?", description, links } = Astro.props;
---

<section class="relative px-2 py-10 sm:py-12">
  <div class="max-w-3xl mx-auto text-center">
    <InkBanner as="h2" class="!text-2xl sm:!text-3xl">
      {title}
    </InkBanner>
    {description && <p class="mt-6 text-warm-600 leading-relaxed">{description}</p>}
    <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center items-center">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              link.variant === "primary" ? "btn-brush" : "btn-brush btn-brush--ghost",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</section>
