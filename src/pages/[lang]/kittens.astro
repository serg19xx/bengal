---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import CatCard from "../../components/CatCard.astro";
import CTASection from "../../components/CTASection.astro";
import { getKittenCats } from "../../data/cats";
import { getStaticLangPaths, isLocale, defaultLocale } from "../../i18n/config";
import type { Locale } from "../../i18n/config";
import { getMessages } from "../../i18n/messages";
import { pathFor } from "../../i18n/paths";

export function getStaticPaths() {
  return getStaticLangPaths();
}

const langParam = Astro.params.lang;
const lang: Locale = isLocale(langParam) ? langParam : defaultLocale;
const m = getMessages(lang);

const kittens = getKittenCats();
---

<Layout lang={lang} title={m.kittensPage.title} description={m.kittensPage.subtitle}>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <SectionTitle
      eyebrow={m.kittensPage.eyebrow}
      title={m.kittensPage.heading}
      subtitle={m.kittensPage.subtitle}
    />

    <p class="max-w-3xl rounded-2xl bg-cream-200/80 px-5 py-4 text-sm leading-relaxed text-soft-800" role="note">
      {m.kittensPage.note}
    </p>

    {
      kittens.length === 0 ? (
        <p class="mt-10 text-warm-600">{m.kittensPage.empty}</p>
      ) : (
        <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {kittens.map((cat) => (
            <CatCard cat={cat} lang={lang} />
          ))}
        </div>
      )
    }

    <div class="mt-16 sm:mt-20">
      <CTASection
        title={m.kittensPage.ctaTitle}
        description={m.kittensPage.ctaDescription}
        links={[
          { href: pathFor(lang, "contact"), label: m.kittensPage.ctaPrimary, variant: "primary" },
          { href: pathFor(lang, "cats"), label: m.kittensPage.ctaSecondary, variant: "secondary" },
        ]}
      />
    </div>
  </div>
</Layout>
