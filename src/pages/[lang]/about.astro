---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import { getStaticLangPaths, isLocale, defaultLocale } from "../../i18n/config";
import type { Locale } from "../../i18n/config";
import { getMessages } from "../../i18n/messages";

export function getStaticPaths() {
  return getStaticLangPaths();
}

const langParam = Astro.params.lang;
const lang: Locale = isLocale(langParam) ? langParam : defaultLocale;
const m = getMessages(lang);
---

<Layout lang={lang} title={m.about.title} description={m.about.lead}>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <header class="max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-widest text-soft-700/80">{m.about.pageKicker}</p>
      <h1 class="mt-3 font-serif text-4xl sm:text-5xl font-semibold text-soft-900 tracking-tight">{m.about.pageTitle}</h1>
      <p class="mt-5 text-lg leading-relaxed text-warm-600">{m.about.lead}</p>
    </header>

    <div class="mt-14 space-y-16">
      <section>
        <SectionTitle title={m.about.storyTitle} subtitle={m.about.storySubtitle} />
        <div class="max-w-3xl text-warm-600 leading-relaxed space-y-4">
          <p>{m.about.storyP1}</p>
          <p>{m.about.storyP2}</p>
        </div>
      </section>

      <section>
        <SectionTitle title={m.about.liveTitle} subtitle={m.about.liveSubtitle} />
        <ul class="grid gap-6 sm:grid-cols-2 max-w-4xl">
          <li class="rounded-3xl border border-beige-300/70 bg-white p-6">
            <h3 class="font-serif text-lg font-semibold text-soft-900">{m.about.liveCard1Title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-warm-600">{m.about.liveCard1Body}</p>
          </li>
          <li class="rounded-3xl border border-beige-300/70 bg-white p-6">
            <h3 class="font-serif text-lg font-semibold text-soft-900">{m.about.liveCard2Title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-warm-600">{m.about.liveCard2Body}</p>
          </li>
        </ul>
      </section>

      <section>
        <SectionTitle title={m.about.careTitle} subtitle={m.about.careSubtitle} />
        <div class="max-w-3xl space-y-4 text-warm-600 leading-relaxed">
          <p>{m.about.careP1}</p>
          <p>{m.about.careP2}</p>
        </div>
      </section>

      <section>
        <SectionTitle title={m.about.principlesTitle} subtitle={m.about.principlesSubtitle} />
        <ol class="max-w-3xl list-decimal space-y-3 pl-5 text-warm-600 leading-relaxed marker:text-soft-800">
          <li>{m.about.principlesLi1}</li>
          <li>{m.about.principlesLi2}</li>
          <li>{m.about.principlesLi3}</li>
          <li>{m.about.principlesLi4}</li>
        </ol>
      </section>
    </div>
  </div>
</Layout>
