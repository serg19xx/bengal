---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import GalleryBrowser from "../../components/vue/GalleryBrowser.vue";
import { getGalleryItems } from "../../data/cats";
import { getStaticLangPaths, isLocale, defaultLocale } from "../../i18n/config";
import type { Locale } from "../../i18n/config";
import { getMessages } from "../../i18n/messages";
import { pathFor } from "../../i18n/paths";

export function getStaticPaths() {
  return getStaticLangPaths();
}

const langParam = Astro.params.lang;
const lang: Locale = isLocale(langParam) ? langParam : defaultLocale;
const m = getMessages(lang);

const items = getGalleryItems(lang);

const galleryUi = {
  ...m.lightbox,
  searchLabel: m.galleryPage.searchLabel,
  searchPlaceholder: m.galleryPage.searchPlaceholder,
  resultCount: m.galleryPage.resultCount,
  emptySearch: m.galleryPage.emptySearch,
  viewProfile: m.galleryPage.viewProfile,
  contactAbout: m.galleryPage.contactAbout,
  age: m.catCard.age,
  gender: m.catCard.gender,
  genderLabels: m.gender,
  statusLabels: m.status,
};
---

<Layout lang={lang} title={m.galleryPage.title} description={m.galleryPage.subtitle}>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <SectionTitle
      eyebrow={m.galleryPage.eyebrow}
      title={m.galleryPage.heading}
      subtitle={m.galleryPage.subtitle}
    />
    <GalleryBrowser
      client:load
      items={items}
      profileBasePath={pathFor(lang, "cats")}
      contactBasePath={pathFor(lang, "contact")}
      ui={galleryUi}
    />
  </div>
</Layout>
