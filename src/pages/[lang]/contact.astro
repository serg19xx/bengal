---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import ContactForm from "../../components/vue/ContactForm.vue";
import { getCatOptionsForForm } from "../../data/cats";
import { getStaticLangPaths, isLocale, defaultLocale } from "../../i18n/config";
import type { Locale } from "../../i18n/config";
import { getMessages } from "../../i18n/messages";

export function getStaticPaths() {
  return getStaticLangPaths();
}

const langParam = Astro.params.lang;
const lang: Locale = isLocale(langParam) ? langParam : defaultLocale;
const m = getMessages(lang);

const catOptions = getCatOptionsForForm();
const initialCat = Astro.url.searchParams.get("cat") ?? "";
const formUi = m.form;
const mailtoEmail =
  import.meta.env.PUBLIC_CONTACT_EMAIL?.toString().trim() || m.contactPage.emailValue;
---

<Layout lang={lang} title={m.contactPage.title} description={m.contactPage.subtitle}>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <div class="grid gap-12 lg:grid-cols-5 lg:gap-16">
      <div class="lg:col-span-2">
        <SectionTitle title={m.contactPage.heading} subtitle={m.contactPage.subtitle} />
        <div class="mt-8 space-y-6 text-warm-600 leading-relaxed">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-warm-500">{m.contactPage.emailLabel}</p>
            <p class="mt-1 font-medium text-soft-900">{m.contactPage.emailValue}</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-warm-500">{m.contactPage.phoneLabel}</p>
            <p class="mt-1 font-medium text-soft-900">{m.contactPage.phoneValue}</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-warm-500">{m.contactPage.locationLabel}</p>
            <p class="mt-1 font-medium text-soft-900">{m.contactPage.locationValue}</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-warm-500">{m.contactPage.socialLabel}</p>
            <ul class="mt-2 flex flex-wrap gap-3 text-sm">
              <li>
                <a href="#" class="text-soft-800 underline-offset-4 hover:underline">Instagram</a>
              </li>
              <li>
                <a href="#" class="text-soft-800 underline-offset-4 hover:underline">Facebook</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
      <div class="lg:col-span-3">
        <ContactForm
          client:load
          mailtoEmail={mailtoEmail}
          catOptions={catOptions}
          initialCatSlug={initialCat}
          ui={formUi}
        />
      </div>
    </div>
  </div>
</Layout>
