---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import CatCard from "../../components/CatCard.astro";
import CTASection from "../../components/CTASection.astro";
import AnnouncementBanner from "../../components/AnnouncementBanner.astro";
import { getAvailableCats } from "../../data/cats";
import { getStaticLangPaths, isLocale, defaultLocale } from "../../i18n/config";
import type { Locale } from "../../i18n/config";
import { getMessages } from "../../i18n/messages";
import { pathFor } from "../../i18n/paths";

export function getStaticPaths() {
  return getStaticLangPaths();
}

const langParam = Astro.params.lang;
const lang: Locale = isLocale(langParam) ? langParam : defaultLocale;
const m = getMessages(lang);

/** Home shows only kittens currently for sale; section omitted when none. */
const availableKittens = getAvailableCats();

/** AI mood placeholders for Hero until real photos replace them. */
const heroImages = [
  "/images/hero/hero-placeholder-1.png",
  "/images/hero/hero-placeholder-2.png",
  "/images/hero/hero-placeholder-3.png",
];
---

<Layout lang={lang} title={m.home.title} description={m.meta.defaultDescription}>
  <Hero
    eyebrow={m.hero.eyebrow}
    title={m.home.heroTitle}
    subtitle={m.home.heroSubtitle}
    images={heroImages}
    imageAlt={m.home.heroImageAlt}
    primaryHref={pathFor(lang, "kittens")}
    primaryLabel={m.hero.primary}
    secondaryHref={pathFor(lang, "cats")}
    secondaryLabel={m.hero.secondary}
  />

  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <AnnouncementBanner text={m.announcement.text} href={pathFor(lang, "kittens")} ctaLabel={m.announcement.cta} />

    <section class="mt-12 sm:mt-16">
      <SectionTitle
        eyebrow={m.home.welcomeEyebrow}
        title={m.home.welcomeTitle}
        subtitle={m.home.welcomeSubtitle}
      />
      <div class="max-w-3xl space-y-4 text-warm-600 leading-relaxed">
        <p>{m.home.welcomeP1}</p>
        <p>{m.home.welcomeP2}</p>
      </div>
    </section>

    <section class="mt-16 sm:mt-20 px-1 py-2">
      <SectionTitle
        eyebrow={m.home.healthEyebrow}
        title={m.home.healthTitle}
        subtitle={m.home.healthSubtitle}
      />
      <ul class="mt-6 max-w-3xl list-disc space-y-3 pl-5 text-warm-600 leading-relaxed marker:text-amber-500">
        <li>{m.home.healthLi1}</li>
        <li>{m.home.healthLi2}</li>
      </ul>
    </section>

    {
      availableKittens.length > 0 && (
        <section class="mt-16 sm:mt-20">
          <SectionTitle
            eyebrow={m.home.availableEyebrow}
            title={m.home.availableTitle}
            subtitle={m.home.availableSubtitle}
          />
          <div
            class:list={[
              "grid w-full gap-8",
              availableKittens.length === 1 && "max-w-md grid-cols-1",
              availableKittens.length === 2 && "grid-cols-1 sm:grid-cols-2",
              availableKittens.length >= 3 && "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3",
            ]}
          >
            {availableKittens.map((cat) => (
              <CatCard cat={cat} lang={lang} />
            ))}
          </div>
          <p class="mt-8">
            <a
              href={pathFor(lang, "kittens")}
              class="text-sm font-semibold text-soft-800 underline decoration-amber-400/70 underline-offset-4 hover:text-burgundy-700"
            >
              {m.home.availableSeeAll}
              <span aria-hidden="true"> →</span>
            </a>
          </p>
        </section>
      )
    }

    <section class="mt-16 sm:mt-20">
      <SectionTitle
        eyebrow={m.home.philosophyEyebrow}
        title={m.home.philosophyTitle}
        subtitle={m.home.philosophySubtitle}
      />
      <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <li class="px-1">
          <h3 class="font-serif text-lg font-semibold text-soft-900">{m.home.card1Title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-warm-600">{m.home.card1Body}</p>
        </li>
        <li class="px-1">
          <h3 class="font-serif text-lg font-semibold text-soft-900">{m.home.card2Title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-warm-600">{m.home.card2Body}</p>
        </li>
        <li class="px-1 sm:col-span-2 lg:col-span-1">
          <h3 class="font-serif text-lg font-semibold text-soft-900">{m.home.card3Title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-warm-600">{m.home.card3Body}</p>
        </li>
      </ul>
    </section>

    <section class="mt-16 sm:mt-20 px-1">
      <h2 class="ink-banner !text-xl sm:!text-2xl font-serif font-semibold">{m.home.pawTeaserTitle}</h2>
      <p class="mt-5 max-w-2xl text-warm-600 leading-relaxed">{m.home.pawTeaserBody}</p>
      <div class="mt-6 flex flex-wrap gap-3 items-center">
        <a href={pathFor(lang, "adoption")} class="btn-brush">
          {m.home.pawTeaserAdoption}
        </a>
        <a
          href={pathFor(lang, "varieties")}
          class="text-sm font-semibold text-soft-800 underline decoration-amber-400/70 underline-offset-4 hover:text-burgundy-700"
        >
          {m.home.pawTeaserVarieties}
        </a>
      </div>
    </section>

    <div class="mt-16 sm:mt-20">
      <CTASection
        title={m.home.ctaTitle}
        links={[
          { href: pathFor(lang, "cats"), label: m.home.ctaPrimary, variant: "primary" },
          { href: pathFor(lang, "contact"), label: m.home.ctaSecondary, variant: "secondary" },
        ]}
      />
    </div>
  </div>
</Layout>
