---
export const prerender = true;
import Layout from "../../../layouts/Layout.astro";
import ImageLightbox from "../../../components/vue/ImageLightbox.vue";
import {
  approximateAgeFromBirth,
  cats,
  formatCatBirthDate,
  getCatBySlug,
  pickLocalized,
} from "../../../data/cats";
import { locales, isLocale, defaultLocale } from "../../../i18n/config";
import type { Locale } from "../../../i18n/config";
import { getMessages } from "../../../i18n/messages";
import { pathFor } from "../../../i18n/paths";

export function getStaticPaths() {
  return locales.flatMap((lang) => cats.map((cat) => ({ params: { lang, slug: cat.slug } })));
}

const langParam = Astro.params.lang;
const slug = Astro.params.slug!;
const lang: Locale = isLocale(langParam) ? langParam : defaultLocale;
const m = getMessages(lang);

const cat = getCatBySlug(slug);

if (!cat) {
  return Astro.redirect(pathFor(lang, "cats"));
}

const description = pickLocalized(cat.personalityShort, lang);
const breed = pickLocalized(cat.breed, lang);
const personality = pickLocalized(cat.personality, lang);
const healthNote = pickLocalized(cat.healthNote, lang);
const parentsNote = pickLocalized(cat.parentsNote, lang);
const vetNotes =
  cat.vetNotes && (cat.vetNotes.en.trim() || cat.vetNotes.fr.trim())
    ? pickLocalized(cat.vetNotes, lang)
    : "";
const statusLabel = m.status[cat.status];
const genderLabel = m.gender[cat.gender];
const hasBirth = Boolean(cat.birthDate && /^\d{4}-\d{2}-\d{2}$/.test(cat.birthDate));
const birthLine = hasBirth
  ? `${formatCatBirthDate(cat.birthDate!, lang)} · ${approximateAgeFromBirth(cat.birthDate!, lang)}`
  : "";
const ageLine = hasBirth ? birthLine : pickLocalized(cat.age, lang);
const galleryAlts = cat.gallery.map((_, i) => `${cat.name} (${i + 1})`);
const lightboxUi = m.lightbox;
---

<Layout lang={lang} title={cat.name} description={description}>
  <article class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <header class="max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-widest text-soft-700/80">{breed}</p>
      <h1 class="mt-2 font-serif text-4xl sm:text-5xl font-semibold text-soft-900 tracking-tight">{cat.name}</h1>
      <p class="mt-3 text-warm-600">
        <span>{ageLine}</span>
        <span class="mx-2 text-warm-400" aria-hidden="true">·</span>
        <span>{genderLabel}</span>
        <span class="mx-2 text-warm-400" aria-hidden="true">·</span>
        <span
          class="inline-flex items-center rounded-full border border-beige-300 bg-cream-100 px-2.5 py-0.5 text-xs font-semibold text-soft-800"
        >
          {statusLabel}
        </span>
      </p>
    </header>

    <div class="mt-10">
      <h2 class="sr-only">{m.catDetail.gallerySr}</h2>
      <ImageLightbox client:load images={cat.gallery} imageAlts={galleryAlts} ui={lightboxUi} />
    </div>

    <div class="mt-14 grid gap-12 lg:grid-cols-3">
      <div class="lg:col-span-2 space-y-6 text-warm-600 leading-relaxed">
        <h2 class="font-serif text-2xl font-semibold text-soft-900">{m.catDetail.personality}</h2>
        <p>{personality}</p>
      </div>
      <aside class="space-y-6">
        <div class="rounded-3xl border border-beige-300/70 bg-white p-6 shadow-sm">
          <h3 class="font-serif text-lg font-semibold text-soft-900">{m.catDetail.health}</h3>
          <p class="mt-2 text-sm leading-relaxed text-warm-600">{healthNote}</p>
        </div>
        {
          vetNotes ? (
            <div class="rounded-3xl border border-beige-300/70 bg-white p-6 shadow-sm">
              <h3 class="font-serif text-lg font-semibold text-soft-900">{m.catDetail.vetCare}</h3>
              <p class="mt-2 text-sm leading-relaxed text-warm-600 whitespace-pre-wrap">{vetNotes}</p>
            </div>
          ) : null
        }
        <div class="rounded-3xl border border-beige-300/70 bg-white p-6 shadow-sm">
          <h3 class="font-serif text-lg font-semibold text-soft-900">{m.catDetail.parents}</h3>
          <p class="mt-2 text-sm leading-relaxed text-warm-600">{parentsNote}</p>
        </div>
        <a
          href={`${pathFor(lang, "contact")}?cat=${cat.slug}`}
          class="flex w-full items-center justify-center rounded-2xl bg-soft-800 px-6 py-3.5 text-sm font-semibold text-cream-50 hover:bg-soft-700 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-soft-700 focus-visible:ring-offset-2"
        >
          {m.catDetail.contactCta} {cat.name}
        </a>
      </aside>
    </div>
  </article>
</Layout>
