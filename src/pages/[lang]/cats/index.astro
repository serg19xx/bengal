---
export const prerender = true;
import Layout from "../../../layouts/Layout.astro";
import SectionTitle from "../../../components/SectionTitle.astro";
import CatPortrait from "../../../components/CatPortrait.astro";
import CTASection from "../../../components/CTASection.astro";
import { getBreedingCats } from "../../../data/cats";
import { getStaticLangPaths, isLocale, defaultLocale } from "../../../i18n/config";
import type { Locale } from "../../../i18n/config";
import { getMessages } from "../../../i18n/messages";
import { pathFor } from "../../../i18n/paths";

export function getStaticPaths() {
  return getStaticLangPaths();
}

const langParam = Astro.params.lang;
const lang: Locale = isLocale(langParam) ? langParam : defaultLocale;
const m = getMessages(lang);

const breeders = getBreedingCats();
---

<Layout lang={lang} title={m.catsPage.title} description={m.catsPage.subtitle}>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <SectionTitle eyebrow={m.catsPage.eyebrow} title={m.catsPage.heading} subtitle={m.catsPage.subtitle} />

    {
      breeders.length === 0 ? (
        <p class="mt-4 text-warm-600">{m.catsPage.empty}</p>
      ) : (
        <div class="mt-4 flex flex-col gap-16 sm:gap-20">
          {breeders.map((cat, i) => (
            <CatPortrait cat={cat} lang={lang} reverse={i % 2 === 1} />
          ))}
        </div>
      )
    }

    <div class="mt-16 sm:mt-20">
      <CTASection
        title={m.catsPage.ctaTitle}
        description={m.catsPage.ctaDescription}
        links={[
          { href: pathFor(lang, "kittens"), label: m.catsPage.ctaPrimary, variant: "primary" },
          { href: pathFor(lang, "contact"), label: m.catsPage.ctaSecondary, variant: "secondary" },
        ]}
      />
    </div>
  </div>
</Layout>
